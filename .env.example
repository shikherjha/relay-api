# relay-api — copy to .env (never commit .env)
PORT=8000

# Datastores (compose injects these; localhost defaults for bare-metal dev)
DATABASE_URL=postgresql://relay:relay@localhost:5432/relay
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1

# Sibling services
ML_SERVICE_URL=http://localhost:8001
ENGINE_SERVICE_URL=http://localhost:8002

# AWS / storage
S3_BUCKET=relay-media
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# LifeLedger (Polygon Amoy testnet) — T2
# Anchors Condition-Passport hashes on-chain. Defaults to a deterministic MOCK
# anchor (no chain) so the demo is always safe. To anchor REAL transactions:
#   1. USE_REAL_LEDGER=true
#   2. LIFELEDGER_PRIVATE_KEY = a key funded with Amoy test-MATIC
#      (free faucet: https://faucet.polygon.technology — pick Amoy)
#   3. POLYGON_RPC_URL = the Amoy RPC (a dedicated Alchemy/Infura URL is more
#      reliable than the public endpoint for a live demo)
# New runtime anchors (return grading, resale, rescue, checkout) then write real
# txs and the LifeLedger UI deep-links each one to PolygonScan.
USE_REAL_LEDGER=false
POLYGON_RPC_URL=https://rpc-amoy.polygon.technology
LIFELEDGER_PRIVATE_KEY=
# Optional registry contract; blank = anchor as a self-tx calldata write.
LIFELEDGER_CONTRACT_ADDRESS=
LIFELEDGER_EXPLORER_BASE_URL=https://amoy.polygonscan.com
LIFELEDGER_NETWORK=Polygon Amoy

# Matching / rescue tunables
EMBEDDING_DIM=384
RESCUE_DEFAULT_RADIUS_KM=3
